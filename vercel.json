{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/data",
      "dest": "/api/data.js"
    },
    {
      "src": "/api/claude-proxy",
      "dest": "/api/claude-proxy.js"
    },
    {
      "src": "/api/tally-webhook",
      "dest": "/api/tally-webhook.js"
    },
    {
      "src": "/api/survey-submit",
      "dest": "/api/survey-submit.js"
    },
    {
      "src": "/api/results",
      "dest": "/api/results.js"
    },
    {
      "src": "/api/submit",
      "dest": "/api/submit.js"
    },
    {
      "src": "/dashboard",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/view",
      "dest": "/public/view.html"
    },
    {
      "src": "/survey(.*)",
      "dest": "/public/survey.html"
    },
    {
      "src": "/",
      "dest": "/public/login.html"
    }
  ]
}