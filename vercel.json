{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/dashboard",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/view",
      "dest": "/public/view.html"
    },
    {
      "src": "/survey",
      "dest": "/public/survey.html"
    },
    {
      "src": "/survey(.*)",
      "dest": "/public/survey.html"
    },
    {
      "src": "/",
      "dest": "/public/login.html"
    }
  ]
}